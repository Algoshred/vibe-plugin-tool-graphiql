{
  "name": "@vibecontrols/vibe-plugin-tool-graphiql",
  "version": "2026.508.2",
  "main": "./dist/index.js",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia && tsc --emitDeclarationOnly --declaration --outDir ./dist && mkdir -p ./dist/ui && cp -r ./src/ui/. ./dist/ui/",
    "dev": "tsc --watch",
    "lint": "eslint ./src",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run build"
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "graphiql",
    "graphql",
    "playground",
    "bun"
  ],
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "description": "GraphQL Playground (GraphiQL) \u2014 embedded in VibeControls agent",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.10",
    "commander": "^14.0.3",
    "elysia": "^1.3.0",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "elysia": ">=1.3.0"
  },
  "peerDependenciesMeta": {
    "elysia": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-tool-graphiql.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-tool-graphiql/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://verdaccio.tooling.internal.burdenoff.com/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "src/ui/**/*",
    "README.md",
    "LICENSE"
  ],
  "overrides": {
    "lodash": ">=4.17.21",
    "lodash-es": ">=4.17.21",
    "dompurify": ">=3.3.4",
    "fast-xml-parser": ">=4.5.5",
    "@xmldom/xmldom": ">=0.8.12",
    "swiper": ">=12.1.2",
    "brace-expansion": ">=1.1.13",
    "follow-redirects": ">=1.15.12",
    "smol-toml": ">=1.6.1",
    "axios": ">=1.15.0",
    "flatted": ">=3.4.1",
    "yaml": ">=2.8.3",
    "picomatch": ">=2.3.2",
    "immutable": ">=3.8.3",
    "minimatch": ">=3.1.3"
  }
}
